{
  "name": "@overbrilliant/ob1",
  "version": "0.1.0",
  "description": "OB-1, the CLI coding agent for Overbrilliant",
  "license": "Apache-2.0",
  "author": "Neu Software LLC",
  "homepage": "https://github.com/tashfeenahmed/ob-1#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tashfeenahmed/ob-1.git"
  },
  "bugs": {
    "url": "https://github.com/tashfeenahmed/ob-1/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "cli",
    "developer-tools",
    "overbrilliant",
    "ob-1",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.13"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "7.0.1",
    "typescript": "^5"
  },
  "bin": {
    "ob1": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "smoke": "bun run scripts/smoke.ts",
    "typecheck": "tsc --noEmit",
    "build:bin": "bun run scripts/build-bin.ts",
    "setup": "bash scripts/install.sh"
  },
  "type": "module",
  "dependencies": {
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.20.8"
  }
}
