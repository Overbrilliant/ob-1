{
  "name": "@overbrilliant/ob1",
  "version": "0.3.5",
  "description": "OB-1, the CLI coding agent for Overbrilliant",
  "license": "Apache-2.0",
  "author": "Neu Software LLC",
  "homepage": "https://github.com/Overbrilliant/ob-1#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Overbrilliant/ob-1.git"
  },
  "bugs": {
    "url": "https://github.com/Overbrilliant/ob-1/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "cli",
    "developer-tools",
    "overbrilliant",
    "ob-1",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "7.0.1",
    "typescript": "^5"
  },
  "bin": {
    "ob1": "bin/ob1.mjs"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "smoke": "bun run scripts/smoke.ts",
    "lint": "biome lint src scripts",
    "format:check": "biome format src scripts --write=false",
    "typecheck": "bun run scripts/generate-version.ts --check && tsc --noEmit",
    "version:sync": "bun run scripts/generate-version.ts",
    "build:bin": "bun run scripts/build-bin.ts",
    "setup": "bash scripts/install.sh"
  },
  "type": "module",
  "dependencies": {
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.20.8"
  },
  "optionalDependencies": {
    "playwright": "^1.61.0"
  }
}
